&initialization_parameters
         ! A neutral ABL precursor with capping inversion.

         nx = 599,
         ny = 399,
         nz = 500,

         ! Domain: 4.8 km x 3.2 km x 4.0 km.
         dx = 8.0,
         dy = 8.0,
         dz = 8.0,

         bc_lr   = 'cyclic',
         bc_ns   = 'cyclic',
         bc_uv_t = 'neumann',

         ! Solve the potential-temperature equation so the cap is active.
         neutral = .FALSE.,

         ! Zero surface sensible-heat flux.
         surface_heatflux = 0.0,
         bc_pt_b          = 'neumann',

         ! Retain the initial free-atmosphere gradient at the domain top.
         bc_pt_t = 'initial_gradient',

         pt_surface = 280.0,

         ! PALM units are K per 100 m.
         !
         ! 0 to 500 m:    neutral
         ! 500 to 600 m: 2 K inversion
         ! above 600 m:  10 K/km stable free atmosphere
         pt_vertical_gradient       = 0.0, 2.0, 1.0,
         pt_vertical_gradient_level = 0.0, 500.0, 600.0,

         roughness_length = 0.1,
         latitude         = 53.83,

         initializing_actions = 'read_restart_data',

         ! Initial geostrophic-wind estimate.
         ! The controller adjusts ug and vg during development.
         ug_surface = 10.0,
         vg_surface = 0.0,
/

&flow_control_parameters
         geostrophic_wind_controller = .TRUE.,

         kp = 10.0,
         ki = 20.0,

         target_height = 90.0,
         target_u      = 8.0,
         target_v      = 0.0,
/

&damping_parameters
         inertial_oscillation_damping_factor = 0.9,
/

&runtime_parameters
         ! Total simulated time: 18 hours plus 5 seconds.
         end_time = 64801.0,

         termination_time_needed = 600.0,
         restart_data_format     = 'mpi',

         ! 50 x 40 = 2000 MPI ranks.
         npex = 50,
         npey = 40,

         ! Explicit turbulence seeding.
         create_disturbances       = .FALSE., ! is not needed for the restart
         dt_disturb                = 150.0,
         disturbance_amplitude     = 0.25,
         disturbance_energy_limit  = 0.01,
         disturbance_level_b       = 20.0,
         disturbance_level_t       = 452.0,

         ! Fifteen-minute averaged profile output.
         dt_dopr               = 900.0,
         averaging_interval_pr = 900.0,
         dt_averaging_input_pr = 2.0,

         data_output_pr = 'u', 'v', 'w',
                          'theta',
                          'wtheta', 'wu', 'wv',
                          'u*2', 'v*2', 'w*2',
                          'e', 'e*',
                          'ug', 'vg',

         ! Parallel NetCDF.
         netcdf_data_format = 5,

         ! Required for native staggered-grid palm_cti input.
         interpolate_to_grid_center = .FALSE.,

         ! Approximate rotor bottom, hub and rotor top.
         section_xy_m = 28.0, 92.0, 156.0,

         ! Mid-domain xz plane, location specified by y.
         section_xz_m = 1600.0,

         ! Mid-domain yz inflow plane, location specified by x.
         section_yz_m = 2400.0,

         data_output = 'u_yz', 'v_yz', 'w_yz',
                       'theta_yz', 'e_yz',
                       'u_xy',
                       'u_xy_av',
                       'u_xz_av',
                       'u_yz_av',

         ! Instantaneous horizontal output only during the final hour.
         skip_time_do2d_xy = 61200.0,
         dt_do2d_xy        = 1800.0,

         ! One-second palm_cti input during the final hour.
         skip_time_do2d_yz = 61200.0,
         dt_do2d_yz        = 1.0,

         ! One-hour averaged cross sections.
         dt_data_output_av        = 3600.0,
         averaging_interval       = 3600.0,
         dt_averaging_input       = 2.0,
         skip_time_data_output_av = 61201.0,
/

&surface_data_output_parameters
         data_output_surf = 'us_av',
                            'usws_av',
                            'vsws_av',
                            'shf_av',
                            'uvw1_av',
                            'theta1_av',
                            'z0_av',

         averaging_interval_surf = 3600.0,
         dt_dosurf_av             = 3600.0,

         ! Suppress the average ending at 17 h.
         ! Retain the final average ending at 18 h.
         skip_time_dosurf_av = 61201.0,

         to_netcdf = .TRUE.,
/

!palmrun -v -B -b -q standard96  -r precursor_pm -c emmy2 -X 2000 -T 96  -a "d3# restart" -t 64800
