 &initialization_parameters
!-- M23 precursor restart leg: identical to the _p3d except initializing_actions. The init-profile
!-- parameters are ignored on restart (forcing and fields come from the restart file) and kept only
!-- as a minimal diff of the _p3d. Raise end_time in &runtime_parameters to extend the spin-up.
         nx = 599, ny = 399, nz = 500,
         dx = 8.0, dy = 8.0, dz = 8.0,

         bc_lr = 'cyclic', bc_ns = 'cyclic',
         bc_uv_t = 'neumann',

         surface_heatflux = 0.0,
         bc_pt_b          = 'neumann',

         pt_surface                 = 278.7,
         pt_vertical_gradient       = 0.1,
         pt_vertical_gradient_level = 1000.0,

         roughness_length = 0.1,
         latitude         = 53.83,

         initializing_actions = 'read_restart_data',
         ug_surface = 10.0, vg_surface = 0.0,
 /

 &flow_control_parameters
!-- Same controller as the _p3d: the gains and targets are read from this namelist (not restored),
!-- so they must be repeated. Only the integral state (error_u_i, error_v_i) is carried over from
!-- the restart file (fct_rrd_global), so the controller resumes without re-winding the integral.
    geostrophic_wind_controller = .TRUE.,
    kp            = 10.0,
    ki            = 20.0,
    target_height = 92.0,
    target_u      = 7.0,
    target_v      = 0.0,
 /

 &damping_parameters
    inertial_oscillation_damping_factor = 0.9,
 /

 &runtime_parameters
         end_time = 52200.0,                    ! UPDT2: set to 50700 raise to extend the spin-up (total physical time)
         termination_time_needed = 600.0,
         restart_data_format     = 'mpi',
         npex = 50, npey = 40,
         dt_disturb = 150.0,
         dt_dopr               = 900.0,
         averaging_interval_pr = 900.0,
         data_output_pr = 'u', 'v', 'w', 'theta', 'wtheta', 'wu', 'wv',
                          'u*2', 'v*2', 'w*2', 'e', 'e*', 'ug', 'vg',

!-- Same streak-check slices as the _p3d (see README). section_*_m are in metres.
         netcdf_data_format = 5,
         section_xy_m       = 92.0,
         section_yz_m       = 2400.0,
         data_output        = 'u_yz', 'v_yz','w_yz','theta_yz','e_yz','u_xy','u_xy_av','u_xy_av', 'u_yz_av',
         dt_do2d_xy         = 1800.0,
         dt_do2d_yz         = 1.0,
         dt_data_output_av  = 3600.0,
         averaging_interval = 3600.0,
         dt_averaging_input = 0.0,
 /
